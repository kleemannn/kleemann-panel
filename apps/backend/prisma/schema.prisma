// Prisma schema for Kleemann Panel
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RESELLER
}

enum ResellerType {
  STANDARD
  PREMIUM
}

enum ClientStatus {
  ACTIVE
  EXPIRED
  DISABLED
  LIMITED
}

model Reseller {
  id          String       @id @default(uuid())
  telegramId  BigInt       @unique
  username    String?
  firstName   String?
  lastName    String?
  // Uppercase alphanumeric tag (max 16 chars) propagated to Remnawave
  // on every client this reseller creates, so admins can attribute
  // remote users back to a reseller. Unique across all resellers.
  tag         String?      @unique
  // Free-form provider identifier assigned by admin (e.g. external billing/partner id).
  // Not enforced unique; purely informational, shown in admin UI.
  providerId  String?
  role        Role         @default(RESELLER)
  type        ResellerType @default(STANDARD)
  maxClients  Int          @default(50)
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  clients     Client[]
  auditLogs   AuditLog[]

  @@index([role])
  @@index([type])
}

model Client {
  id             String       @id @default(uuid())
  resellerId     String
  reseller       Reseller     @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  remnawaveUuid  String       @unique
  username       String       @unique
  telegramId     BigInt?
  note           String?
  subscriptionUrl String?
  shortUuid      String?
  expiresAt      DateTime?
  trafficLimitGb Int?                         // null = unlimited
  squadUuid      String
  status         ClientStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([resellerId])
  @@index([status])
}

// Mapping reseller type -> Remnawave internal squad UUID.
// Can be overridden via admin UI; falls back to env SQUAD_*_UUID.
model SquadMapping {
  id        String       @id @default(uuid())
  type      ResellerType @unique
  squadUuid String
  label     String?
  updatedAt DateTime     @updatedAt
}

model AuditLog {
  id         String    @id @default(uuid())
  resellerId String?
  reseller   Reseller? @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  actor      String                          // "admin:<id>" | "reseller:<id>"
  action     String                          // "client.create", "reseller.create", ...
  targetId   String?
  payload    Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([resellerId, createdAt])
  @@index([action])
}

// History of bulk IP/address replacements performed by the admin
// against Remnawave hosts grouped by tag (or one specific host uuid).
// Used to display "what changed when" in the admin UI and to roll back manually.
model HostIpChange {
  id               String   @id @default(uuid())
  // Either a tag (bulk over all hosts with this tag) or null when targeting a single host.
  tag              String?
  // When targeting a single host directly, store its Remnawave uuid.
  hostUuid         String?
  previousAddress  String?
  newAddress       String
  previousPort     Int?
  newPort          Int?
  hostsAffected    Int      @default(0)
  hostsFailed      Int      @default(0)
  performedBy      String                          // "admin:<id>"
  note             String?
  createdAt        DateTime @default(now())

  @@index([tag, createdAt])
  @@index([hostUuid, createdAt])
}
