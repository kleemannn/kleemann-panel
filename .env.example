# ==== Backend ====
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Postgres
DATABASE_URL=postgresql://kleemann:kleemann@postgres:5432/kleemann?schema=public

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:PLACEHOLDER
# Comma-separated list of Telegram IDs that will be auto-promoted to ADMIN on first login
ADMIN_TELEGRAM_IDS=

# Remnawave Panel
REMNAWAVE_BASE_URL=https://panel.example.com
REMNAWAVE_TOKEN=replace-with-panel-api-token

# Optional: default squad UUIDs; can also be configured via admin UI
SQUAD_STANDARD_UUID=
SQUAD_PREMIUM_UUID=

# Optional: Happ cover-domain rewrite. When both vars are set, bot rewrites
# Remnawave subscription URLs into:
#   https://{HAPP_COVER_HOST}/sub/{shortUuid}#?resolve-address={HAPP_COVER_HOST}&host={HAPP_BACKEND_HOST}&providerid={reseller.providerId}
# COVER_HOST is the visible benign host, BACKEND_HOST is the real host Happ
# should connect to (usually a reverse-proxy / Cloud Run in front of Remnawave).
HAPP_COVER_HOST=
HAPP_BACKEND_HOST=

# CORS: URL of your Mini App frontend (include Telegram Web domain)
CORS_ORIGINS=http://localhost:5173,https://web.telegram.org

# ==== Frontend ====
VITE_API_URL=http://localhost:4000/api/v1
