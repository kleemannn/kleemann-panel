{
  "name": "kleemann-panel",
  "private": true,
  "version": "0.1.0",
  "description": "Telegram Mini App for VPN/Proxy resellers on top of Remnawave Panel API",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "backend:dev": "pnpm --filter @kleemann/backend run dev",
    "frontend:dev": "pnpm --filter @kleemann/frontend run dev",
    "prisma:migrate": "pnpm --filter @kleemann/backend exec prisma migrate dev",
    "prisma:generate": "pnpm --filter @kleemann/backend exec prisma generate",
    "seed": "pnpm --filter @kleemann/backend run seed"
  },
  "engines": {
    "node": ">=20.10.0"
  }
}
